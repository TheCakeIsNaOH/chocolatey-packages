<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>github-desktop</id>
    <title>GitHub Desktop</title>
    <version>3.6.1</version>
    <packageSourceUrl>https://github.com/TheCakeIsNaOH/Chocolatey-Packages/tree/master/</packageSourceUrl>
    <authors>GitHub</authors>
    <owners>TheCakeIsNaOH</owners>
    <summary>Focus on what matters instead of fighting with Git. Whether you're new to Git or a seasoned user, GitHub Desktop simplifies your development workflow.</summary>
    <description>
With GitHub Desktop, you can interact with GitHub using a GUI instead of the command line or a web browser. You can use GitHub Desktop to complete most Git commands from your desktop, such as pushing to, pulling from, and cloning remote repositories, attributing commits, and creating pull requests, with visual confirmation of changes.

## This essentially replaces https://chocolatey.org/packages/GitHub but is a different application.
    </description>
    <projectUrl>https://github.com/apps/desktop</projectUrl>
    <projectSourceUrl>https://github.com/desktop/desktop</projectSourceUrl>
    <docsUrl>https://docs.github.com/en/desktop</docsUrl>
    <bugTrackerUrl>https://github.com/desktop/desktop/issues</bugTrackerUrl>
    <tags>admin electron git github desktop typescript developer</tags>
    <copyright>© GitHub, Inc. All rights reserved.</copyright>
    <licenseUrl>https://github.com/desktop/desktop/blob/development/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <iconUrl>https://cdn.statically.io/gh/TheCakeIsNaOH/chocolatey-packages/775ac37179c4c8bc14ed55d62af30795eba9d3e2/Icons/github-desktop.png</iconUrl>
    <releaseNotes>https://desktop.github.com/release-notes/</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
